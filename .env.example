# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=payment_gateway
DB_USER=postgres
DB_PASSWORD=admin

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
PAYMENT_KAFKA_ENABLED=true
PAYMENT_KAFKA_TOPIC=payment.events

# Payment Encryption Key (Generate a new secure key for production)
PAYMENT_ENCRYPTION_KEY_BASE64=your-secure-base64-key-here

# Server Configuration
PORT=8080
LOG_LEVEL=INFO
SQL_LOG_LEVEL=WARN
SECURITY_LOG_LEVEL=INFO
SHOW_SQL=false
FLYWAY_ENABLED=true
